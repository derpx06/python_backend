# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskapi
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/taskapi

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_REFRESH_SECRET_KEY=your-refresh-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
PORT=4000
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:3000

# Admin seed
ADMIN_EMAIL=admin@taskapi.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Admin User
